                    <code style="background: none;">📧📞 проверка</code>
                </div>
            </div>
        </div>

        <!-- карточка Snoop -->
        <div class="card-service" style="padding: 1.8rem 2rem; margin-bottom: 1.8rem;">
            <div style="display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap;">
                <div class="api-icon"><i class="fas fa-search"></i></div>
